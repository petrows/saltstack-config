# CCTV timelapse service configuration
output_dir: /srv/cctv-timelapse/data
interval: 60    # seconds between capture rounds
timeout: 15     # seconds before a single capture attempt is aborted
retries: 3      # extra attempts when a capture fails (0 = no retries)
retry_delay: 5  # seconds to wait between attempts

cameras:
  - name: front-door
    url: rtsp://user:pass@10.0.0.10:554/stream1
  - name: backyard
    url: http://10.0.0.11/snapshot.jpg
