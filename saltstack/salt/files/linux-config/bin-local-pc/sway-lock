#!/bin/bash
# {% raw %}

set -euo pipefail

# set -x

ensure_single_instance() {
    # Default lockfile name derived from the script's basename.
    local lockfile="${1:-/tmp/$(basename "$0").pid}"

    if [[ -f "$lockfile" ]]; then
        local old_pid
        old_pid="$(cat "$lockfile" 2>/dev/null || true)"

        # Is the recorded PID a live process?  kill -0 tests existence
        # without sending a real signal.
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            echo "Already running (pid $old_pid) — exiting." >&2
            exit 1
        fi
        # Stale lockfile (process is gone) — fall through and reclaim it.
    fi

    # Record our PID and clean up the lockfile when we exit (any reason).
    echo "$$" > "$lockfile"
    # shellcheck disable=SC2064
    trap "rm -f '$lockfile'" EXIT INT TERM
}

ensure_single_instance "${XDG_RUNTIME_DIR}/sway-lock.pid"

# Reset current layout to default (US)
# to allow promt be always-correct
swaymsg input type:keyboard xkb_switch_layout 0

# Turn ON indicator led
led-kb-set scrolllock 1

# Cache folder for processed images
BG_CACHE_PATH="${HOME}/.cache/sway-bg"
# Image processing params
declare -a BG_ARGS=()
# Blur image a bit
#BG_ARGS+=( -blur 20x20 )
# Faster variant from https://stackoverflow.com/a/48443430
BG_ARGS+=( -scale 20% -gaussian-blur 0x2.5 -resize 500% )
# Add text
BG_ARGS+=( -font DejaVu-Sans -pointsize 48 -fill white -gravity south -annotate +0+50 "Peter Kopf" )
# Add 'lock' icon
BG_ARGS+=( '(' /opt/swaylock-fancy/icons/white.png -background none -alpha on ')' -gravity north -geometry +0+256 )
# Reduce colors a bit
BG_ARGS+=( -modulate 100,50 )

# Swaylock args
SWAYLOCK_CMD="swaylock"
declare -a SWAYLOCK_ARGS=()

mkdir -p "${BG_CACHE_PATH}"

# Generate BG image
# Get the list of output names currently known to Sway.
mapfile -t OUTPUTS < <(swaymsg -t get_outputs | jq -r '.[].name')
for OUTPUT in "${OUTPUTS[@]}"; do
    BG_PATH=$(readlink -f $XDG_RUNTIME_DIR/sway-bg/$OUTPUT)
    if [[ ! -f "$BG_PATH" ]]; then
        echo "Skipping: ${BG_PATH}"
        continue
    fi

    # Calculate output file path (hashed)
    BG_HASH=$(echo -n "${BG_PATH}" "${BG_ARGS[@]}" | md5sum | awk '{print $1}')
    BG_OUT_PATH="$BG_CACHE_PATH/lock-${BG_HASH}.jpg"

    echo "Output $OUTPUT has $BG_PATH -> ${BG_OUT_PATH}"

    if [[ ! -f "${BG_OUT_PATH}" ]]; then
        magick "${BG_PATH}" "${BG_ARGS[@]}" -composite "${BG_OUT_PATH}"
    fi
    SWAYLOCK_ARGS+=( --image "${OUTPUT}:${BG_OUT_PATH}" )
done

# try to use swaylock with prepared parameters
if ! "${SWAYLOCK_CMD}" "${SWAYLOCK_ARGS[@]}" >/dev/null 2>&1; then
    # We have failed, lets get back to stock one
    "${SWAYLOCK_CMD}"
fi

# Turn OFF indicator led
led-kb-set scrolllock 0

# Cleanup cache folder a bit (90 days -> remove)
find "${BG_CACHE_PATH}" -maxdepth 1 -type f -name '*.jpg' -mtime +90 -delete

# {% endraw %}
