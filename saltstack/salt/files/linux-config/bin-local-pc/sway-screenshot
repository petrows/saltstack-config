#!/usr/bin/env bash
#
# screenshot.sh — read a PNG from stdin, save the original, open an editor.
#
# The capture tool (grim) runs OUTSIDE this script and is piped in:
#
#   grim - | screenshot.sh
#   grim -g "$(slurp)" - | screenshot.sh
#   grim -o DP-1 - | screenshot.sh
#
# What it does:
#   1. Reads image bytes from stdin.
#   2. Saves the original to ~/screenshot/<timestamp>.png
#   3. Opens an editor on that file for optional annotation / copy.
#
# Env overrides:
#   SHOT_DIR     save directory   (default: ~/screenshot)
#   SHOT_EDITOR  editor command   (default: satty, falls back to swappy)
#                The saved file path is appended as the final argument.

set -euo pipefail

SHOT_DIR="${SHOT_DIR:-$HOME/Pictures/screenshots}"
mkdir -p "$SHOT_DIR"

FILE="$SHOT_DIR/Screenshot_$(hostname)_-$(date +%F_%H-%M-%S).png"

# 1. Persist stdin (the grim capture) to the original file.
cat > "$FILE"

# Guard: if nothing came in on stdin, don't open an editor on an empty file.
if [[ ! -s "$FILE" ]]; then
    rm -f "$FILE"
    echo "No image received on stdin — nothing saved." >&2
    exit 1
fi

echo "Saved: $FILE"

# Copy filename to clipboard
echo "$FILE" | wl-copy

# 2. Choose the editor and open the SAVED FILE (not a stream).
if [[ -n "${SHOT_EDITOR:-}" ]]; then
    # User-provided command; file path appended as last arg.
    exec $SHOT_EDITOR "$FILE"
elif command -v satty >/dev/null; then
    exec satty --filename "$FILE"
elif command -v swappy >/dev/null; then
    exec swappy -f "$FILE"
else
    echo "No editor found (install satty or swappy, or set SHOT_EDITOR)." >&2
    echo "Original is saved at: $FILE" >&2
    exit 0
fi
